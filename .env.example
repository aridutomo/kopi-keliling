# Contoh konfigurasi — SALIN ke `.env` (production) atau `.env.staging`, lalu isi nilai asli.
# JANGAN taruh kredensial asli di file ini (file ini ikut ter-commit).

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ganti-dengan-password-kuat
DB_NAME=anaki_coffee

MYSQL_ROOT_PASSWORD=ganti-dengan-password-kuat
DB_HOST_PORT=3306

# ─── App ─────────────────────────────────────────────────────────────────────
# Port di laptop/VPS untuk mengakses aplikasi (http://localhost:HOST_PORT)
HOST_PORT=7001

# WAJIB string acak panjang. Generate: openssl rand -hex 32
JWT_SECRET=ganti-dengan-string-acak-panjang

# ─── Gin ─────────────────────────────────────────────────────────────────────
GIN_MODE=release
