# ══════════════════════════════════════════════════════════════════════════════
#  STAGING — contoh konfigurasi. SALIN ke `.env.staging`, lalu isi nilai asli.
#  JANGAN taruh kredensial asli di file ini (file ini ikut ter-commit).
#  Jalankan: ./stg.sh up -d --build   (project: anaki-stg)
#  Terpisah total dari production: container, volume, port, dan DB berbeda.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ganti-dengan-password-kuat-staging
DB_NAME=stg_anaki_coffee

# Harus SAMA dengan DB_PASSWORD (app login sebagai root)
MYSQL_ROOT_PASSWORD=ganti-dengan-password-kuat-staging
DB_HOST_PORT=3307          # MySQL staging di localhost:3307 (prod pakai 3306)

# ─── App ─────────────────────────────────────────────────────────────────────
# Buka http://localhost:7002  (prod pakai 7001)
HOST_PORT=7002

# WAJIB string acak panjang & berbeda dari production. Generate: openssl rand -hex 32
JWT_SECRET=ganti-dengan-string-acak-panjang-staging

# Alias jaringan untuk reverse proxy Caddy (harus cocok dengan Caddyfile)
PROXY_UPSTREAM=app-stg

# ─── Gin ─────────────────────────────────────────────────────────────────────
GIN_MODE=debug
